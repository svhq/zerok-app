# Relay configuration — copy to `.env` and fill in.
# All values are read from process.env at startup.

# Network ('devnet' or 'mainnet')
NETWORK=mainnet

# Solana RPC endpoint(s). Comma-separated for failover.
# Use a paid provider (Helius/Triton/Alchemy) — public endpoints rate-limit relays.
RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_API_KEY
RPC_URLS=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_API_KEY,https://api.mainnet-beta.solana.com

# Relay fee-payer keypair (JSON byte array string).
# This wallet pays gas + nullifier-PDA rent for every withdrawal it submits.
# Funded from accumulated 0.3% protocol fees.
RELAYER_PRIVATE_KEY=[1,2,3,...,64]

# Pool config — JSON inline (production) OR file path (local dev)
POOL_CONFIG_JSON={"pools":[...]}
# Local dev alternative:
# CONFIG_PATH=../generated/config/mainnet.json

# Program ID
PROGRAM_ID_V2=HVcTokFF4rwvcU7sC7GjS317CSf7QDgfCvW7edijKS2v

# Address Lookup Tables — one per denomination (lamports).
# 30-account withdraw txs require ALTs to fit in 1232 bytes.
V3_ALT_100000000=<ALT_PUBKEY_FOR_0.1_SOL_POOL>
V3_ALT_1000000000=<ALT_PUBKEY_FOR_1_SOL_POOL>
V3_ALT_10000000000=<ALT_PUBKEY_FOR_10_SOL_POOL>
V3_ALT_100000000000=<ALT_PUBKEY_FOR_100_SOL_POOL>
V3_ALT_1000000000000=<ALT_PUBKEY_FOR_1000_SOL_POOL>

# Server
PORT=8789

# Operational tuning
RELAY_MODE=subsidized       # 'subsidized' = relay pays gas (default)
MAX_CONCURRENCY=4           # max parallel submissions
